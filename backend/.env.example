PORT=3001
NODE_ENV=development

# JWT Settings
JWT_SECRET=secret
JWT_EXPIRES_IN=7d

# Mongo Settings
MONGODB_URI=mongodb+srv://
MONGODB_USERNAME=mongousername
MONGODB_PASSWORD=mongopassword

# Local Backend (Express)
FRONTEND_URL=http://localhost:3000

